{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Haul Calc",
  "version": "1.0.0",
  "identifier": "id.jenss.haulcalc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Haul Calc",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQ0YwNzEzMDExNjI0QgpSV1JMWWhFd2NmRDhCV1ZacEFlaFlXalhYUXR2YzZuSHhWLzFsQTdMcmo0cFlRbkpKNmNBRzZFZAo=",
      "endpoints": [
        "https://github.com/rachmad-jenss/haul-calc/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "startMenuFolder": "Haul Calc"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "hcalc"
        ],
        "name": "HaulCalc Project",
        "mimeType": "application/x-haulcalc",
        "description": "HaulCalc Project File",
        "role": "Editor"
      }
    ],
    "externalBin": [
      "binaries/haulpave-bridge"
    ],
    "resources": [
      "../public/sample_fleet.json"
    ],
    "category": "Business",
    "shortDescription": "Mining haul road pavement calculations",
    "longDescription": "Desktop GUI for CESA, CBR/TRH 14 pavement thickness, and operating cost comparison. Wraps the haul-pave Python library."
  }
}
