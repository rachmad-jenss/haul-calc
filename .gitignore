# Tauri-generated platform icons — all committed so CI can build without pnpm tauri icon
# src-tauri/icons/*.png
# src-tauri/icons/*.ico
# src-tauri/icons/*.icns

# Python sidecar
python-sidecar/.venv/
python-sidecar/__pycache__/
python-sidecar/build/
python-sidecar/dist/
python-sidecar/*.spec

# Generated
*.tsbuildinfo

# E2E test output (generated at runtime, not tracked)
tests/screenshots/
tests/playwright-report/
tests/test-results/

# AI tool files (not for public repo)
CLAUDE.md
CONTRIBUTING.md
TEMPLATES.md
.claude/
